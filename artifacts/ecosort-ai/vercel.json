{
  "buildCommand": "cd ../.. && npm install -g pnpm && pnpm install --frozen-lockfile && pnpm --filter @workspace/ecosort-ai run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
